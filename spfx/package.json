{
  "name": "tnsu-inventory-spfx",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0 <23.0.0"
  },
  "scripts": {
    "build": "heft build",
    "build:frontend": "npm run build:embed --prefix ../frontend",
    "bundle": "npm run build:frontend && heft build --production",
    "package-solution": "npm run build:frontend && heft build --production && heft package-solution --production",
    "serve": "npm run build:frontend && heft build && heft build-watch --serve",
    "clean": "heft clean"
  },
  "dependencies": {
    "@microsoft/sp-component-base": "1.22.1",
    "@microsoft/sp-core-library": "1.22.1",
    "@microsoft/sp-lodash-subset": "1.22.1",
    "@microsoft/sp-office-ui-fabric-core": "1.22.1",
    "@microsoft/sp-property-pane": "1.22.1",
    "@microsoft/sp-webpart-base": "1.22.1",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "@microsoft/eslint-config-spfx": "1.22.1",
    "@microsoft/eslint-plugin-spfx": "1.22.2",
    "@microsoft/sp-module-interfaces": "1.22.1",
    "@microsoft/sp-build-web": "1.22.1",
    "@microsoft/spfx-heft-plugins": "1.22.1",
    "@microsoft/spfx-web-build-rig": "1.22.1",
    "@rushstack/eslint-config": "4.5.2",
    "@rushstack/heft": "1.1.2",
    "@types/heft-jest": "1.0.2",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "8.57.0",
    "gulp": "4.0.2",
    "typescript": "~5.8.0"
  }
}
