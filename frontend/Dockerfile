FROM node:22-alpine AS build
WORKDIR /app

ARG VITE_ENTRA_CLIENT_ID=
ARG VITE_ENTRA_TENANT_ID=
ARG VITE_ENTRA_AUDIENCE=
ARG VITE_ENTRA_API_SCOPE=
ARG VITE_ENTRA_REDIRECT_URI=
ARG VITE_APP_BRAND_NAME=Tansu
ARG VITE_APP_COMPANY_NAME=ТАНСУ
ARG VITE_SHOW_DEV_LOGIN=false

ENV VITE_ENTRA_CLIENT_ID=$VITE_ENTRA_CLIENT_ID
ENV VITE_ENTRA_TENANT_ID=$VITE_ENTRA_TENANT_ID
ENV VITE_ENTRA_AUDIENCE=$VITE_ENTRA_AUDIENCE
ENV VITE_ENTRA_API_SCOPE=$VITE_ENTRA_API_SCOPE
ENV VITE_ENTRA_REDIRECT_URI=$VITE_ENTRA_REDIRECT_URI
ENV VITE_APP_BRAND_NAME=$VITE_APP_BRAND_NAME
ENV VITE_APP_COMPANY_NAME=$VITE_APP_COMPANY_NAME
ENV VITE_SHOW_DEV_LOGIN=$VITE_SHOW_DEV_LOGIN

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS final
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
